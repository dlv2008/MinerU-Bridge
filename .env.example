# MinerU API 监听地址
MINERU_HOST=0.0.0.0

# MinerU API 监听端口
MINERU_PORT=8886

# 模型来源: huggingface / modelscope / local
# 中国大陆环境建议先用 modelscope 下载，再切换到 local
MINERU_MODEL_SOURCE=modelscope

# 服务端最大并发请求数
MINERU_API_MAX_CONCURRENT_REQUESTS=1

# 任务结果保留时长，单位秒
MINERU_API_TASK_RETENTION_SECONDS=86400

# 任务清理轮询间隔，单位秒
MINERU_API_TASK_CLEANUP_INTERVAL_SECONDS=300

# 是否开启 FastAPI 文档
MINERU_API_ENABLE_FASTAPI_DOCS=true

# 是否启用公式解析
MINERU_FORMULA_ENABLE=true

# 是否启用表格解析
MINERU_TABLE_ENABLE=true

# 是否在服务启动时预热 VLM
# 仅在明确使用相关 VLM backend 时再考虑开启
MINERU_ENABLE_VLM_PRELOAD=false
